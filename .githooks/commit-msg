#!/bin/sh

message_file="$1"
first_line="$(head -n 1 "$message_file")"

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([A-Za-z0-9._-]+\))?!?: .+'

if printf '%s' "$first_line" | grep -Eq "$pattern"; then
  exit 0
fi

printf '%s\n' "Commit message must follow Conventional Commits." >&2
printf '%s\n' "Example: feat(engine): add self-play runner" >&2
exit 1
